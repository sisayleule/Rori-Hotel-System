{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon rori-hotel/server/server.js",
    "dev:client": "npm --prefix rori-hotel/client run dev",
    "start": "node rori-hotel/server/server.js",
    "build": "npm --prefix rori-hotel/client run build",
    "preview": "node rori-hotel/server/server.js",
    "clean": "rm -rf rori-hotel/client/dist",
    "lint": "echo 'No linter check needed for JS server'"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.18.0",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "concurrently": "^10.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.546.0",
    "mongoose": "^9.7.1",
    "motion": "^12.23.24",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.1",
    "nodemon": "^3.1.14",
    "pdfkit": "^0.19.1",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-router-dom": "^7.18.0",
    "recharts": "^3.8.1",
    "uuid": "^14.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
