# Node.js dependencies - contains all installed npm packages that can be reinstalled from package.json
node_modules

# Environment variables - contains sensitive secrets like passwords and API keys that must never be committed
.env
.env.local
.env.production.local

# Build output - compiled production files that can be regenerated from source code
dist
build

# Uploaded files - user-generated content including profile photos and internship application letters
uploads

# IDE and editor files - workspace specific settings
.vscode
.idea
*.swp
*.swo
*~

# Operating system files - automatically generated by Windows, Mac, Linux
.DS_Store
Thumbs.db
desktop.ini

# Log files - runtime logs and debug output that should not be version controlled
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Testing coverage - test reports and coverage data that can be regenerated
coverage
*.lcov
.nyc_output

# Temporary files - cache and temporary data created during development
.cache
.temp
.tmp

# Certificate files - generated PDF certificates stored temporarily
certificates

# Package manager lock files for alternative package managers
yarn.lock
pnpm-lock.yaml
