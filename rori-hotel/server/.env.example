# =======================================================================================
# RORI HOTEL INTERNSHIP MANAGEMENT SYSTEM - ENVIRONMENT VARIABLES CONFIGURATION
# =======================================================================================
# This file contains all required environment variables for the backend server.
# Copy this file to .env and fill in your actual values before running the application.
# Never commit the actual .env file to version control - it contains sensitive secrets.
# =======================================================================================

# SERVER CONFIGURATION
# Port number where the backend server will run - Render uses dynamic PORT in production
PORT=5000

# DATABASE CONFIGURATION
# MongoDB Atlas connection string - replace with your actual MongoDB Atlas cluster URL
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
# Get this from MongoDB Atlas dashboard > Connect > Connect your application
MONGODB_URI=mongodb+srv://your-username:your-password@cluster0.xxxxx.mongodb.net/?appName=Cluster0

# JWT AUTHENTICATION
# Secret key for signing JWT tokens - use a long random string for security
# Generate a secure random string using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_random_secret_string_here_minimum_32_characters_long

# CLOUDINARY FILE STORAGE
# Cloudinary cloud name - found in your Cloudinary dashboard
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
# Cloudinary API key for authentication - found in Cloudinary dashboard
CLOUDINARY_API_KEY=your_cloudinary_api_key
# Cloudinary API secret for secure access - found in Cloudinary dashboard under API Keys
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# EMAIL CONFIGURATION FOR NOTIFICATIONS
# Gmail address that will send system notification emails to students and staff
EMAIL_USER=your-email@gmail.com
# Gmail app-specific password - NOT your regular Gmail password
# Generate from: Google Account > Security > 2-Step Verification > App passwords
# Format: 16 characters with spaces like "abcd efgh ijkl mnop"
EMAIL_PASS=your-gmail-app-password-here

# FRONTEND CORS CONFIGURATION
# Development frontend URL - typically http://localhost:3000 for local Vite/React
CLIENT_URL=http://localhost:3000
# Production frontend URL - will be your Vercel deployment URL after frontend deployment
# Format: https://your-project-name.vercel.app
CLIENT_URL_PROD=https://your-vercel-url-here.vercel.app

# ENVIRONMENT MODE
# Set to 'production' when deploying to Render or 'development' for local testing
NODE_ENV=production

# DEFAULT USER SEEDING
# Set to true only in local/demo environments when you intentionally want default staff users created.
SEED_DEFAULT_USERS=false

# BACKEND URL
# The public URL where your backend API is deployed - used for email links and certificates
# For Render deployment format: https://your-service-name.onrender.com
BACKEND_URL=https://your-render-url-here.onrender.com

# =======================================================================================
# DEPLOYMENT CHECKLIST
# =======================================================================================
# [ ] MongoDB Atlas: Whitelist IP 0.0.0.0/0 in Network Access to allow Render servers
# [ ] Cloudinary: Create account and get credentials from dashboard
# [ ] Gmail: Enable 2-Step Verification and generate App Password
# [ ] Render: Add all these environment variables in the Render dashboard
# [ ] Vercel: Add VITE_API_URL pointing to your Render backend URL
# =======================================================================================
